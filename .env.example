# Copier vers .env et remplir les valeurs

PORT=3000
NODE_ENV=development
FREE_MODE=true

# JWT
JWT_SECRET=change_me
JWT_REFRESH_SECRET=change_me
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Google Sign-In (OAuth client ID)
GOOGLE_CLIENT_ID=

# Base de données (Prisma)
DATABASE_URL=postgresql://user:password@localhost:5432/ecopower

# --- Email (Gmail) ---
# Gmail n’accepte PLUS le mot de passe du compte : il faut un « mot de passe d’application ».
# 1. https://myaccount.google.com/security → Validation en 2 étapes : ACTIVER
# 2. https://myaccount.google.com/apppasswords → créer un mot de passe pour « Mail »
# 3. Coller les 16 caractères (sans espaces) dans SMTP_PASSWORD
#
# Pour le dev local SANS envoyer d’emails :
EMAIL_ENABLED=false

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre.compte@gmail.com
SMTP_PASSWORD=mot_de_passe_application_16_caracteres

EMAIL_LOGO_URL=https://votre-api.example.com/logo.png
CONTACT_EMAIL=votre.compte@gmail.com
